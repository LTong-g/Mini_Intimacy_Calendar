{
  "name": "minimalistweaponenhancementcalendar",
  "version": "2.2.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android --device AVD_2640x1200",
    "android:phone": "expo run:android --device AVD_2640x1200",
    "android:tablet": "expo run:android --device AVD_2560x1600",
    "android:build:debug:tempmap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-tempmap.ps1 -GradleTask assembleDebug",
    "android:build:release:tempmap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-tempmap.ps1 -GradleTask assembleRelease -NodeEnv production",
    "android:install:debug:tempmap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-build-tempmap.ps1 -GradleTask installDebug",
    "android:archive:release": "powershell -ExecutionPolicy Bypass -File .\\scripts\\archive-android-release.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "release:sync-version": "eas build:version:sync"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.4.4",
    "@react-navigation/native": "^7.1.16",
    "@react-navigation/native-stack": "^7.3.23",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "moment": "^2.30.1",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-paper": "^5.14.5",
    "react-native-portalize": "^1.0.7",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.12.0",
    "react-native-vector-icons": "^10.3.0",
    "expo-updates": "~0.28.17",
    "expo": "~53.0.20"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "expo": "^53.0.20"
  },
  "private": true
}
